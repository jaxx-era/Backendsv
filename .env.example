PORT=5000

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-backend-domain.com/api/auth/google/callback

# Google Business
GOOGLE_BUSINESS_KEY=your_business_key
GOOGLE_BUSINESS_SECRET=your_business_secret

# Google Gemini Keys (10)
GEMINI_KEY_1=...
GEMINI_KEY_2=...
GEMINI_KEY_3=...
GEMINI_KEY_4=...
GEMINI_KEY_5=...
GEMINI_KEY_6=...
GEMINI_KEY_7=...
GEMINI_KEY_8=...
GEMINI_KEY_9=...
GEMINI_KEY_10=...

# Razorpay
RAZORPAY_KEY_ID=...
RAZORPAY_SECRET=...

# MongoDB
MONGO_URI=your_mongo_connection_string

# JWT
JWT_SECRET=supersecretkey
